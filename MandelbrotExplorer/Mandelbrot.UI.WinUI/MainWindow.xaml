<Window
    x:Class="Mandelbrot.UI.WinUI.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="using:Mandelbrot.UI.WinUI.ViewModels"
    xmlns:core="using:Mandelbrot.Core.Models"
    mc:Ignorable="d"
    Title="Mandelbrot Explorer Premium">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid x:Name="AppTitleBar" Grid.Row="0" Height="32" Background="Transparent" />

        <Grid Grid.Row="1" ColumnDefinitions="300, *">
            <!-- Sidebar Panel -->
            <Border Grid.Column="0" Background="#222222" Padding="15">
                <StackPanel Spacing="20">
                    <TextBlock Text="Settings" FontWeight="Bold" FontSize="18" Foreground="White"/>

                    <TextBlock Text="Max Iterations:" Foreground="White"/>
                    <Slider Minimum="50" Maximum="2000" Value="{x:Bind ViewModel.MaxIterations, Mode=TwoWay}" TickFrequency="50" SnapsTo="Ticks" />
                    <TextBlock Text="{x:Bind ViewModel.MaxIterations, Mode=OneWay}" Foreground="Gray" HorizontalAlignment="Right"/>

                    <TextBlock Text="Color Theme:" Foreground="White"/>
                    <ComboBox ItemsSource="{x:Bind ViewModel.AvailableThemes, Mode=OneWay}" SelectedItem="{x:Bind ViewModel.SelectedTheme, Mode=TwoWay}" HorizontalAlignment="Stretch"/>

                    <Button Content="Save Bookmark" Command="{x:Bind ViewModel.AddBookmarkCommand}" HorizontalAlignment="Stretch"/>

                    <TextBlock Text="Bookmarks:" FontWeight="Bold" FontSize="16" Foreground="White" Margin="0,10,0,0"/>
                    <ListView ItemsSource="{x:Bind ViewModel.Bookmarks, Mode=OneWay}" SelectedItem="{x:Bind ViewModel.SelectedBookmark, Mode=TwoWay}" Height="150">
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="core:Bookmark">
                                <TextBlock Text="{x:Bind Name}" />
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>

                    <Button Content="Export 4K Image..." Click="ExportButton_Click" HorizontalAlignment="Stretch" Background="#0078D7" Foreground="White" Margin="0,20,0,0"/>
                </StackPanel>
            </Border>

            <!-- Main Viewport Area -->
            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Canvas Grid.Row="0"
                        Background="Black"
                        x:Name="ViewportCanvas"
                        PointerPressed="ViewportCanvas_PointerPressed"
                        PointerMoved="ViewportCanvas_PointerMoved"
                        PointerReleased="ViewportCanvas_PointerReleased"
                        SizeChanged="ViewportCanvas_SizeChanged">

                    <Image Source="{x:Bind ViewModel.FractalImageSource, Mode=OneWay}"
                           Width="{x:Bind ViewModel.ViewportWidth, Mode=OneWay}"
                           Height="{x:Bind ViewModel.ViewportHeight, Mode=OneWay}"
                           Stretch="Fill" />

                    <Rectangle Visibility="{x:Bind ViewModel.IsSelecting, Mode=OneWay}"
                               Canvas.Left="{x:Bind ViewModel.SelectionRectangleX, Mode=OneWay}"
                               Canvas.Top="{x:Bind ViewModel.SelectionRectangleY, Mode=OneWay}"
                               Width="{x:Bind ViewModel.SelectionRectangleWidth, Mode=OneWay}"
                               Height="{x:Bind ViewModel.SelectionRectangleHeight, Mode=OneWay}"
                               Stroke="White"
                               StrokeThickness="2"
                               StrokeDashArray="4,4"
                               Fill="#40FFFFFF" />
                </Canvas>

                <Border Grid.Row="1" Background="#333333" Padding="10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0"
                                   Text="{x:Bind ViewModel.StatusText, Mode=OneWay}"
                                   Foreground="White"
                                   VerticalAlignment="Center"/>

                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="10">
                            <Button Content="Zoom Out"
                                    Command="{x:Bind ViewModel.ZoomOutCommand}"
                                    IsEnabled="{x:Bind ViewModel.CanZoomOut, Mode=OneWay}" />
                            <Button Content="Reset"
                                    Command="{x:Bind ViewModel.ResetCommand}" />
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Window>
