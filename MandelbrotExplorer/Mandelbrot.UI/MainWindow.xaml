<Window
    x:Class="Mandelbrot.UI.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="using:Mandelbrot.UI.ViewModels"
    mc:Ignorable="d"
    Title="Mandelbrot Explorer">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Custom Title Bar Area (Height set from code behind) -->
        <Grid x:Name="AppTitleBar" Grid.Row="0" Height="32" Background="Transparent" />

        <!-- Viewport -->
        <Canvas Grid.Row="1"
                Background="Black"
                x:Name="ViewportCanvas"
                PointerPressed="ViewportCanvas_PointerPressed"
                PointerMoved="ViewportCanvas_PointerMoved"
                PointerReleased="ViewportCanvas_PointerReleased"
                SizeChanged="ViewportCanvas_SizeChanged">

            <Image Source="{x:Bind ViewModel.FractalImageSource, Mode=OneWay}"
                   Width="{x:Bind ViewModel.ViewportWidth, Mode=OneWay}"
                   Height="{x:Bind ViewModel.ViewportHeight, Mode=OneWay}"
                   Stretch="Fill" />

            <!-- Selection Overlay -->
            <Rectangle Visibility="{x:Bind ViewModel.IsSelecting, Mode=OneWay}"
                       Canvas.Left="{x:Bind ViewModel.SelectionRectangleX, Mode=OneWay}"
                       Canvas.Top="{x:Bind ViewModel.SelectionRectangleY, Mode=OneWay}"
                       Width="{x:Bind ViewModel.SelectionRectangleWidth, Mode=OneWay}"
                       Height="{x:Bind ViewModel.SelectionRectangleHeight, Mode=OneWay}"
                       Stroke="White"
                       StrokeThickness="2"
                       StrokeDashArray="4,4"
                       Fill="#40FFFFFF" />
        </Canvas>

        <!-- Status & Controls -->
        <Border Grid.Row="2" Background="#333333" Padding="10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Text="{x:Bind ViewModel.StatusText, Mode=OneWay}"
                           Foreground="White"
                           VerticalAlignment="Center"/>

                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="10">
                    <Button Content="Zoom Out"
                            Command="{x:Bind ViewModel.ZoomOutCommand}"
                            IsEnabled="{x:Bind ViewModel.CanZoomOut, Mode=OneWay}" />
                    <Button Content="Reset"
                            Command="{x:Bind ViewModel.ResetCommand}" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
