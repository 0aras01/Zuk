<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Mandelbrot.UI.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="650"
        x:Class="Mandelbrot.UI.Views.MainWindow"
        x:DataType="vm:MainViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Title="Mandelbrot Explorer">

    <Design.DataContext>
        <!-- This only sets the DataContext for the previewer in an IDE,
             to set the actual DataContext for runtime, set the DataContext property in code (look at App.axaml.cs) -->
        <vm:MainViewModel/>
    </Design.DataContext>

    <Grid RowDefinitions="*, Auto">

        <!-- Viewport -->
        <Canvas Grid.Row="0"
                Background="Black"
                Name="ViewportCanvas"
                PointerPressed="ViewportCanvas_PointerPressed"
                PointerMoved="ViewportCanvas_PointerMoved"
                PointerReleased="ViewportCanvas_PointerReleased"
                SizeChanged="ViewportCanvas_OnSizeChanged"
                ClipToBounds="True">

            <Image Source="{Binding FractalImage}"
                   Width="{Binding ViewportWidth}"
                   Height="{Binding ViewportHeight}"
                   Stretch="Fill" />

            <!-- Selection Overlay -->
            <Rectangle IsVisible="{Binding IsSelecting}"
                       Canvas.Left="{Binding SelectionRectangle.X}"
                       Canvas.Top="{Binding SelectionRectangle.Y}"
                       Width="{Binding SelectionRectangle.Width}"
                       Height="{Binding SelectionRectangle.Height}"
                       Stroke="White"
                       StrokeThickness="2"
                       StrokeDashArray="4,4"
                       Fill="#40FFFFFF" />

            <!-- Computation Diagnostics Panel -->
            <Border Canvas.Left="15"
                    Canvas.Top="15"
                    Background="#D01E1E1E"
                    BorderBrush="#40FFFFFF"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="12"
                    Width="320"
                    IsHitTestVisible="False">
                <StackPanel Spacing="6">
                    <TextBlock Text="DIAGNOSTICS &amp; COMPUTATION" Foreground="#FF9E00" FontSize="10" FontWeight="Bold" LetterSpacing="1"/>
                    
                    <Separator Margin="0,2" Height="1" Background="#20FFFFFF"/>
                    
                    <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto" ColumnDefinitions="85,*">
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Zoom:" Foreground="#A0FFFFFF" FontSize="11"/>
                        <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding ZoomText}" Foreground="White" FontSize="11" FontWeight="SemiBold"/>
                        
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Engine:" Foreground="#A0FFFFFF" FontSize="11"/>
                        <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding EngineText}" Foreground="White" FontSize="11"/>
                        
                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Iterations:" Foreground="#A0FFFFFF" FontSize="11"/>
                        <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding IterationsText}" Foreground="White" FontSize="11"/>
                        
                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Render Time:" Foreground="#A0FFFFFF" FontSize="11"/>
                        <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding RenderTimeText}" Foreground="White" FontSize="11"/>
                        
                        <TextBlock Grid.Row="4" Grid.Column="0" Text="Resolution:" Foreground="#A0FFFFFF" FontSize="11"/>
                        <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding ResolutionText}" Foreground="White" FontSize="11"/>
                        
                        <TextBlock Grid.Row="5" Grid.Column="0" Text="Span:" Foreground="#A0FFFFFF" FontSize="11"/>
                        <TextBlock Grid.Row="5" Grid.Column="1" Text="{Binding SpanText}" Foreground="White" FontSize="11" TextWrapping="Wrap"/>
                    </Grid>

                    <Separator Margin="0,2" Height="1" Background="#20FFFFFF"/>
                    
                    <TextBlock Text="Center Coordinates:" Foreground="#A0FFFFFF" FontSize="11"/>
                    <TextBlock Text="{Binding CenterCoordinatesText}" Foreground="#FFCC00" FontSize="10" FontFamily="Consolas,Monospace" TextWrapping="Wrap"/>
                </StackPanel>
            </Border>
        </Canvas>

        <!-- Status & Controls -->
        <Border Grid.Row="1" Background="#333333" Padding="10">
            <Grid ColumnDefinitions="*, Auto">
                <TextBlock Grid.Column="0"
                           Text="{Binding StatusText}"
                           Foreground="White"
                           VerticalAlignment="Center"/>

                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="10">
                    <Button Content="Zoom Out"
                            Command="{Binding ZoomOutCommand}"
                            IsEnabled="{Binding CanZoomOut}" />
                    <Button Content="Reset"
                            Command="{Binding ResetCommand}" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
