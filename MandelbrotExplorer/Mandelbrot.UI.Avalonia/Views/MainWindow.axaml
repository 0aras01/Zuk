<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Mandelbrot.UI.Avalonia.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="1000" d:DesignHeight="700"
        x:Class="Mandelbrot.UI.Avalonia.Views.MainWindow"
        x:DataType="vm:MainViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Title="Mandelbrot Explorer Premium"
        SizeChanged="TopLevel_OnSizeChanged">

    <Grid ColumnDefinitions="300, *">
        <!-- Sidebar Panel -->
        <Border Grid.Column="0" Background="#222222" Padding="15">
            <StackPanel Spacing="20">
                <TextBlock Text="Settings" FontWeight="Bold" FontSize="18" Foreground="White"/>

                <TextBlock Text="Max Iterations:" Foreground="White"/>
                <Slider Minimum="50" Maximum="2000" Value="{Binding MaxIterations}" TickFrequency="50" IsSnapToTickEnabled="True" />
                <TextBlock Text="{Binding MaxIterations}" Foreground="Gray" HorizontalAlignment="Right"/>

                <TextBlock Text="Color Theme:" Foreground="White"/>
                <ComboBox ItemsSource="{Binding AvailableThemes}" SelectedItem="{Binding SelectedTheme}" HorizontalAlignment="Stretch"/>

                <Button Content="Save Bookmark" Command="{Binding AddBookmarkCommand}" HorizontalAlignment="Stretch"/>

                <TextBlock Text="Bookmarks:" FontWeight="Bold" FontSize="16" Foreground="White" Margin="0,10,0,0"/>
                <ListBox ItemsSource="{Binding Bookmarks}" SelectedItem="{Binding SelectedBookmark}" Height="150">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Name}" />
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <Button Content="Export 4K Image..." Click="ExportButton_Click" HorizontalAlignment="Stretch" Background="#0078D7" Foreground="White" Margin="0,20,0,0"/>
            </StackPanel>
        </Border>

        <!-- Main Viewport Area -->
        <Grid Grid.Column="1" RowDefinitions="*, Auto">
            <Canvas Grid.Row="0"
                    Background="Black"
                    Name="ViewportCanvas"
                    PointerPressed="ViewportCanvas_PointerPressed"
                    PointerMoved="ViewportCanvas_PointerMoved"
                    PointerReleased="ViewportCanvas_PointerReleased"
                    ClipToBounds="True">

                <Image Source="{Binding FractalImage}"
                       Width="{Binding ViewportWidth}"
                       Height="{Binding ViewportHeight}"
                       Stretch="Fill" />

                <Rectangle IsVisible="{Binding IsSelecting}"
                           Canvas.Left="{Binding SelectionRectangle.X}"
                           Canvas.Top="{Binding SelectionRectangle.Y}"
                           Width="{Binding SelectionRectangle.Width}"
                           Height="{Binding SelectionRectangle.Height}"
                           Stroke="White"
                           StrokeThickness="2"
                           StrokeDashArray="4,4"
                           Fill="#40FFFFFF" />
            </Canvas>

            <Border Grid.Row="1" Background="#333333" Padding="10">
                <Grid ColumnDefinitions="*, Auto">
                    <TextBlock Grid.Column="0"
                               Text="{Binding StatusText}"
                               Foreground="White"
                               VerticalAlignment="Center"/>

                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="10">
                        <Button Content="Zoom Out"
                                Command="{Binding ZoomOutCommand}"
                                IsEnabled="{Binding CanZoomOut}" />
                        <Button Content="Reset"
                                Command="{Binding ResetCommand}" />
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
