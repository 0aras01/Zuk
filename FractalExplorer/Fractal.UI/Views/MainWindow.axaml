<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Fractal.UI.ViewModels"
        xmlns:models="using:Fractal.Core.Models"
        xmlns:services="using:Fractal.UI.Services"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="1000" d:DesignHeight="700"
        x:Class="Fractal.UI.Views.MainWindow"
        x:DataType="vm:MainViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Title="{Binding [AppName], Source={x:Static services:LocalizationService.Instance}}"
        KeyDown="Window_KeyDown"
        Background="Black">

    <Design.DataContext>
        <vm:MainViewModel/>
    </Design.DataContext>

    <Grid>
        <!-- Viewport Canvas (fills the entire window) -->
        <Canvas Name="ViewportCanvas"
                Background="Black"
                PointerPressed="ViewportCanvas_PointerPressed"
                PointerMoved="ViewportCanvas_PointerMoved"
                PointerReleased="ViewportCanvas_PointerReleased"
                SizeChanged="ViewportCanvas_OnSizeChanged"
                ClipToBounds="True"
                PointerWheelChanged="ViewportCanvas_PointerWheelChanged">

            <Image Source="{Binding Rendering.FractalImage}"
                   Width="{Binding Navigation.ViewportWidth}"
                   Height="{Binding Navigation.ViewportHeight}"
                   Stretch="Fill">
                <Image.RenderTransform>
                    <TranslateTransform X="{Binding Navigation.PanOffsetX}" Y="{Binding Navigation.PanOffsetY}" />
                </Image.RenderTransform>
            </Image>

            <!-- Selection Overlay -->
            <Rectangle IsVisible="{Binding Navigation.IsSelecting}"
                       Canvas.Left="{Binding Navigation.SelectionRectangle.X}"
                       Canvas.Top="{Binding Navigation.SelectionRectangle.Y}"
                       Width="{Binding Navigation.SelectionRectangle.Width}"
                       Height="{Binding Navigation.SelectionRectangle.Height}"
                       Stroke="White"
                       StrokeThickness="2"
                       StrokeDashArray="4,4"
                       Fill="#40FFFFFF" />

            <!-- Orbit Path Overlay -->
            <Polyline IsVisible="{Binding IsOrbitPathVisible}"
                      Points="{Binding OrbitPoints}"
                      Stroke="#FF9E00"
                      StrokeThickness="2"
                      StrokeJoin="Round"
                      StrokeLineCap="Round" />
        </Canvas>

        <!-- Floating UI Overlays Container (HitTest is transparent so clicks pass through to Canvas) -->
        <Grid RowDefinitions="*, Auto" ColumnDefinitions="*, Auto">
            
            <!-- Left Side Panel: Diagnostics (floating on top left) -->
            <Border Grid.Row="0" Grid.Column="0"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Top"
                    Margin="15,15,0,0"
                    Width="320"
                    Background="#E5181818"
                    BorderBrush="#25FFFFFF"
                    BorderThickness="1"
                    CornerRadius="8"
                    BoxShadow="0 4 15 0 #90000000"
                    Padding="12"
                    IsHitTestVisible="False"
                    IsVisible="{Binding Diagnostics.IsDiagnosticsVisible}">
                <StackPanel Spacing="6">
                    <TextBlock Text="{Binding [DiagnosticsTitle], Source={x:Static services:LocalizationService.Instance}}" 
                               Foreground="#FF9E00" FontSize="10" FontWeight="Bold" LetterSpacing="1"/>
                    
                    <Separator Margin="0,2" Height="1" Background="#20FFFFFF"/>
                    
                    <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto" ColumnDefinitions="95,*">
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="{Binding [Zoom], Source={x:Static services:LocalizationService.Instance}}" Foreground="#A0FFFFFF" FontSize="11"/>
                        <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding Diagnostics.ZoomText}" Foreground="White" FontSize="11" FontWeight="SemiBold"/>
                        
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="{Binding [Engine], Source={x:Static services:LocalizationService.Instance}}" Foreground="#A0FFFFFF" FontSize="11"/>
                        <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding Diagnostics.EngineText}" Foreground="White" FontSize="11"/>
                        
                        <TextBlock Grid.Row="2" Grid.Column="0" Text="{Binding [Iterations], Source={x:Static services:LocalizationService.Instance}}" Foreground="#A0FFFFFF" FontSize="11"/>
                        <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding Diagnostics.IterationsText}" Foreground="White" FontSize="11"/>
                        
                        <TextBlock Grid.Row="3" Grid.Column="0" Text="{Binding [RenderTime], Source={x:Static services:LocalizationService.Instance}}" Foreground="#A0FFFFFF" FontSize="11"/>
                        <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding Diagnostics.RenderTimeText}" Foreground="White" FontSize="11"/>
                        
                        <TextBlock Grid.Row="4" Grid.Column="0" Text="{Binding [Resolution], Source={x:Static services:LocalizationService.Instance}}" Foreground="#A0FFFFFF" FontSize="11"/>
                        <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding Diagnostics.ResolutionText}" Foreground="White" FontSize="11"/>
                        
                        <TextBlock Grid.Row="5" Grid.Column="0" Text="{Binding [Span], Source={x:Static services:LocalizationService.Instance}}" Foreground="#A0FFFFFF" FontSize="11"/>
                        <TextBlock Grid.Row="5" Grid.Column="1" Text="{Binding Diagnostics.SpanText}" Foreground="White" FontSize="11" TextWrapping="Wrap"/>
                    </Grid>

                    <Separator Margin="0,2" Height="1" Background="#20FFFFFF"/>
                    
                    <TextBlock Text="{Binding [CenterCoordinates], Source={x:Static services:LocalizationService.Instance}}" Foreground="#A0FFFFFF" FontSize="11"/>
                    <TextBlock Text="{Binding Diagnostics.CenterCoordinatesText}" Foreground="#FFCC00" FontSize="10" FontFamily="Consolas,Monospace" TextWrapping="Wrap" Cursor="Hand" PointerPressed="CenterCoordinates_PointerPressed" ToolTip.Tip="Click to copy full precision coordinates"/>
                </StackPanel>
            </Border>

            <!-- Top Right: Small floating hamburger button (only visible when Sidebar is collapsed) -->
            <Button Grid.Row="0" Grid.Column="1"
                    Content="≡"
                    Command="{Binding ToggleSidePanelCommand}"
                    Width="36" Height="36"
                    Margin="0,15,15,0"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Top"
                    Background="#E5181818"
                    Foreground="White"
                    BorderBrush="#25FFFFFF"
                    BorderThickness="1"
                    CornerRadius="6"
                    FontSize="18"
                    Padding="0"
                    HorizontalContentAlignment="Center"
                    VerticalContentAlignment="Center"
                    IsVisible="{Binding !IsSidePanelVisible}"/>

            <!-- Right Side Panel: Floating Collapsible Control Sidebar -->
            <Border Grid.Row="0" Grid.Column="1"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Stretch"
                    Margin="0,15,15,0"
                    Width="280"
                    Background="#F0181818"
                    BorderBrush="#25FFFFFF"
                    BorderThickness="1"
                    CornerRadius="8"
                    BoxShadow="0 4 20 0 #A0000000"
                    Padding="14"
                    IsVisible="{Binding IsSidePanelVisible}">
                <Grid RowDefinitions="Auto, *">
                    <!-- Sidebar Header -->
                    <Grid Grid.Row="0" ColumnDefinitions="*, Auto" Margin="0,0,0,10">
                        <TextBlock Grid.Column="0" 
                                   Text="{Binding [AppName], Source={x:Static services:LocalizationService.Instance}}" 
                                   Foreground="#FF9E00" FontSize="13" FontWeight="Bold" LetterSpacing="1"
                                   VerticalAlignment="Center"/>
                        <Button Grid.Column="1" 
                                Content="▶" 
                                Command="{Binding ToggleSidePanelCommand}"
                                Width="28" Height="28"
                                Background="Transparent" Foreground="#A0FFFFFF"
                                BorderBrush="Transparent"
                                HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                                Padding="0" FontSize="11"/>
                    </Grid>

                    <!-- Sidebar Content (Scrollable to prevent overflow) -->
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                        <StackPanel Spacing="12" Margin="0,0,4,0">
                            
                            <Separator Height="1" Background="#20FFFFFF"/>

                            <!-- Language & Settings -->
                            <StackPanel Spacing="4">
                                <TextBlock Text="{Binding [Language], Source={x:Static services:LocalizationService.Instance}}" Foreground="#A0FFFFFF" FontSize="11"/>
                                <ComboBox ItemsSource="{Binding Languages}"
                                          SelectedItem="{Binding SelectedLanguage}"
                                          HorizontalAlignment="Stretch"
                                          Height="30" />
                            </StackPanel>

                            <!-- Diagnostics Toggle -->
                            <CheckBox IsChecked="{Binding Diagnostics.IsDiagnosticsVisible}"
                                      Content="{Binding [DiagnosticsToggle], Source={x:Static services:LocalizationService.Instance}}"
                                      Foreground="White" FontSize="12" Margin="0,4,0,0"/>

                            <!-- Minimap Toggle -->
                            <CheckBox IsChecked="{Binding IsMinimapVisible}"
                                      Content="{Binding [Minimap], Source={x:Static services:LocalizationService.Instance}}"
                                      Foreground="White" FontSize="12" Margin="0,4,0,0"/>

                            <!-- Orbit Path Toggle -->
                            <CheckBox IsChecked="{Binding IsOrbitPathVisible}"
                                      Content="{Binding [OrbitPath], Source={x:Static services:LocalizationService.Instance}}"
                                      Foreground="White" FontSize="12" Margin="0,4,0,0"/>

                            <!-- Scientific Notation Toggle -->
                            <CheckBox IsChecked="{Binding IsScientificNotationEnabled}"
                                      Content="{Binding [ScientificNotation], Source={x:Static services:LocalizationService.Instance}}"
                                      Foreground="White" FontSize="12" Margin="0,4,0,0"/>

                            <Separator Height="1" Background="#20FFFFFF"/>

                            <!-- Fractal Selector -->
                            <StackPanel Spacing="4">
                                <TextBlock Text="{Binding [Fractal], Source={x:Static services:LocalizationService.Instance}}" Foreground="#A0FFFFFF" FontSize="11"/>
                                <ComboBox ItemsSource="{Binding Rendering.FractalTypes}"
                                          SelectedItem="{Binding Rendering.SelectedFractalType}"
                                          HorizontalAlignment="Stretch"
                                          Height="30" />
                            </StackPanel>

                            <!-- Julia Parameters -->
                            <StackPanel Spacing="6" IsVisible="{Binding Rendering.IsJuliaSettingsVisible}" Margin="0,4,0,0">
                                <TextBlock Text="{Binding [JuliaReal], Source={x:Static services:LocalizationService.Instance}}" Foreground="#A0FFFFFF" FontSize="11"/>
                                <TextBox Text="{Binding Rendering.JuliaReal}" Height="28" Padding="6,2" FontSize="11" Background="#30000000" BorderBrush="#20FFFFFF"/>
                                
                                <TextBlock Text="{Binding [JuliaImag], Source={x:Static services:LocalizationService.Instance}}" Foreground="#A0FFFFFF" FontSize="11"/>
                                <TextBox Text="{Binding Rendering.JuliaImag}" Height="28" Padding="6,2" FontSize="11" Background="#30000000" BorderBrush="#20FFFFFF"/>
                            </StackPanel>

                            <!-- Coloring Palette -->
                            <StackPanel Spacing="4">
                                <TextBlock Text="{Binding [Palette], Source={x:Static services:LocalizationService.Instance}}" Foreground="#A0FFFFFF" FontSize="11"/>
                                <ComboBox ItemsSource="{Binding Rendering.Palettes}"
                                          SelectedItem="{Binding Rendering.SelectedPalette}"
                                          HorizontalAlignment="Stretch"
                                          Height="30">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Name}" />
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>
                                <Grid ColumnDefinitions="*, *">
                                    <CheckBox Grid.Column="0" IsChecked="{Binding Rendering.IsColorCycling}" Content="Color Cycling" Foreground="White" FontSize="11" Margin="0,4,0,0"/>
                                    <Button Grid.Column="1" Content="Edit Palette" Command="{Binding Rendering.OpenPaletteEditorCommand}" Margin="0,4,0,0" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"/>
                                </Grid>
                            </StackPanel>

                            <Separator Height="1" Background="#20FFFFFF"/>

                            <!-- Bookmarks / Presets -->
                            <StackPanel Spacing="6">
                                <TextBlock Text="{Binding [PresetsTitle], Source={x:Static services:LocalizationService.Instance}}" Foreground="#FF9E00" FontSize="11" FontWeight="SemiBold"/>
                                
                                <ListBox ItemsSource="{Binding Navigation.Bookmarks}" 
                                         SelectedItem="{Binding Navigation.SelectedBookmark}" 
                                         Height="120" 
                                         Background="#30000000" 
                                         BorderBrush="#20FFFFFF" 
                                         BorderThickness="1" 
                                         CornerRadius="4"
                                         Padding="2">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate DataType="models:BookmarkEntry">
                                            <Grid ColumnDefinitions="*, Auto">
                                                <TextBlock Grid.Column="0" Text="{Binding Name}" VerticalAlignment="Center" FontSize="11" Foreground="White" TextTrimming="CharacterEllipsis"/>
                                                <Button Grid.Column="1" 
                                                        Content="✖" 
                                                        Command="{Binding $parent[Window].((vm:MainViewModel)DataContext).Navigation.DeleteBookmarkCommand}" 
                                                        CommandParameter="{Binding}"
                                                        Background="Transparent" Foreground="#FF4444" 
                                                        FontSize="9" Padding="4,2" 
                                                        BorderBrush="Transparent"
                                                        Margin="4,0,0,0"/>
                                            </Grid>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>

                                <!-- Add Bookmark form -->
                                <Grid ColumnDefinitions="*, Auto" ColumnSpacing="6">
                                    <TextBox Grid.Column="0" 
                                             PlaceholderText="{Binding [BookmarkNamePrompt], Source={x:Static services:LocalizationService.Instance}}" 
                                             Text="{Binding Navigation.NewBookmarkName}" 
                                             Height="28" Padding="6,2" FontSize="11" 
                                             Background="#30000000" BorderBrush="#20FFFFFF"/>
                                    <Button Grid.Column="1" 
                                             Content="+" 
                                             Command="{Binding Navigation.AddBookmarkCommand}"
                                             Width="28" Height="28"
                                             Background="#E03C3C3C" Foreground="White"
                                             BorderBrush="#25FFFFFF" BorderThickness="1"
                                             HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                                             Padding="0"/>
                                </Grid>
                            </StackPanel>

                            <Separator Height="1" Background="#20FFFFFF"/>

                            <!-- Actions -->
                            <StackPanel Spacing="8">
                                <Button Content="{Binding [PlayAnimation], Source={x:Static services:LocalizationService.Instance}}"
                                        Command="{Binding Rendering.ToggleAnimationCommand}"
                                        IsVisible="{Binding !Rendering.IsAnimating}"
                                        HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"/>
                                <Button Content="{Binding [StopAnimation], Source={x:Static services:LocalizationService.Instance}}"
                                        Command="{Binding Rendering.ToggleAnimationCommand}"
                                        IsVisible="{Binding Rendering.IsAnimating}"
                                        HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                                        Background="#80FF4444"/>
                                <Button Content="{Binding [ZoomOut], Source={x:Static services:LocalizationService.Instance}}"
                                        Command="{Binding Navigation.ZoomOutCommand}"
                                        IsEnabled="{Binding Navigation.CanZoomOut}"
                                        HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"/>
                                <Button Content="{Binding [Reset], Source={x:Static services:LocalizationService.Instance}}"
                                        Command="{Binding Navigation.ResetCommand}"
                                        HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"/>
                                <Button Content="{Binding [SaveImage], Source={x:Static services:LocalizationService.Instance}}"
                                        Command="{Binding Rendering.SaveImageCommand}"
                                        HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"/>
                                <Button Content="{Binding [CopyToClipboard], Source={x:Static services:LocalizationService.Instance}}"
                                        Command="{Binding Rendering.CopyToClipboardCommand}"
                                        HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"/>
                                <Button Content="{Binding [ExportPoster], Source={x:Static services:LocalizationService.Instance}}"
                                        Command="{Binding StartHighResExportCommand}"
                                        HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"/>
                            </StackPanel>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Border>

            <!-- Bottom Floating Panel: Coordinates & Status (spans bottom width) -->
            <Border Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2"
                    Margin="15"
                    Height="36"
                    Background="#E5151515"
                    BorderBrush="#25FFFFFF"
                    BorderThickness="1"
                    CornerRadius="6"
                    BoxShadow="0 4 12 0 #80000000"
                    Padding="12,0"
                    VerticalAlignment="Bottom">
                <Grid ColumnDefinitions="Auto, *, Auto">
                    <!-- Coordinates under cursor -->
                    <TextBlock Grid.Column="0"
                               Text="{Binding Navigation.CursorCoordinatesText}"
                               Foreground="#FFCC00"
                               FontFamily="Consolas,Monospace"
                               FontSize="11"
                               VerticalAlignment="Center"
                               MinWidth="220"
                               Cursor="Hand"
                               PointerPressed="CursorCoordinates_PointerPressed"
                               ToolTip.Tip="Click to copy full precision coordinates"/>
                    
                    <!-- App Status Message -->
                    <TextBlock Grid.Column="1"
                               Text="{Binding Rendering.StatusText}"
                               Foreground="White"
                               FontSize="11"
                               Margin="15,0,0,0"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Left"
                               TextTrimming="CharacterEllipsis"/>

                    <!-- Keyboard help hint -->
                    <TextBlock Grid.Column="2"
                               Text="{Binding [SidePanelToggle], Source={x:Static services:LocalizationService.Instance}}"
                               Foreground="#80FFFFFF"
                               FontSize="10"
                               VerticalAlignment="Center"/>
                </Grid>
            </Border>

            <!-- Bottom Left: Minimap / Navigation Map (Bird's Eye View) -->
            <Border Grid.Row="0" Grid.Column="0"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Bottom"
                    Margin="15,0,0,15"
                    Width="160" Height="120"
                    Background="#E5151515"
                    BorderBrush="#25FFFFFF"
                    BorderThickness="1"
                    CornerRadius="6"
                    BoxShadow="0 4 12 0 #90000000"
                    ClipToBounds="True"
                    IsVisible="{Binding IsMinimapVisible}">
                <Canvas Name="MinimapCanvas" 
                        Width="160" Height="120" 
                        Background="Transparent"
                        PointerPressed="MinimapCanvas_PointerPressed"
                        PointerMoved="MinimapCanvas_PointerMoved">
                    <Image Source="{Binding MinimapImage}" 
                           Width="160" Height="120" 
                           Stretch="Fill"/>
                    <Rectangle Canvas.Left="{Binding MinimapViewportRect.X}"
                               Canvas.Top="{Binding MinimapViewportRect.Y}"
                               Width="{Binding MinimapViewportRect.Width}"
                               Height="{Binding MinimapViewportRect.Height}"
                               Stroke="#FF9E00"
                               StrokeThickness="1.5"
                               Fill="#20FF9E00"/>
                </Canvas>
            </Border>
        </Grid>

        <!-- R4 Cancel Render Glassmorphic Overlay (displays on top when render takes > 5 seconds) -->
        <Grid Background="#30000000"
              IsVisible="{Binding Rendering.IsCancelOverlayVisible}"
              HorizontalAlignment="Stretch"
              VerticalAlignment="Stretch">
            <Border Width="260"
                    Height="180"
                    Background="#E5101010"
                    BorderBrush="#30FFFFFF"
                    BorderThickness="1"
                    CornerRadius="12"
                    BoxShadow="0 8 32 0 #C0000000"
                    Padding="20"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">
                <StackPanel Spacing="16" VerticalAlignment="Center" HorizontalAlignment="Center">
                    <!-- Subtle Circular Loading Animation (Infinitely rotating dashed Ellipse) -->
                    <Ellipse Width="36" Height="36"
                             Stroke="#FF9E00"
                             StrokeThickness="3"
                             StrokeDashArray="6,4"
                             HorizontalAlignment="Center"
                             RenderTransformOrigin="50%,50%">
                        <Ellipse.RenderTransform>
                            <RotateTransform />
                        </Ellipse.RenderTransform>
                        <Ellipse.Styles>
                            <Style Selector="Ellipse">
                                <Style.Animations>
                                    <Animation Duration="0:0:1.2" IterationCount="Infinite">
                                        <KeyFrame KeyTime="0:0:0">
                                            <Setter Property="RotateTransform.Angle" Value="0"/>
                                        </KeyFrame>
                                        <KeyFrame KeyTime="0:0:1.2">
                                            <Setter Property="RotateTransform.Angle" Value="360"/>
                                        </KeyFrame>
                                    </Animation>
                                </Style.Animations>
                            </Style>
                        </Ellipse.Styles>
                    </Ellipse>

                    <TextBlock Text="{Binding [StatusGenerating], Source={x:Static services:LocalizationService.Instance}}"
                               Foreground="White"
                               FontSize="13"
                               FontWeight="SemiBold"
                               HorizontalAlignment="Center"/>

                    <Button Content="{Binding [CancelButtonText], Source={x:Static services:LocalizationService.Instance}}"
                            Command="{Binding Rendering.CancelRenderCommand}"
                            Background="#D03A3A"
                            Foreground="White"
                            BorderBrush="#FF6060"
                            BorderThickness="1"
                            CornerRadius="6"
                            Padding="12,6"
                            FontWeight="Bold"
                            HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
